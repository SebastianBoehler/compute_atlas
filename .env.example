NODE_ENV=development
LOG_LEVEL=info
DATABASE_URL=postgres://postgres:postgres@localhost:55432/compute_atlas
APP_BASE_URL=http://localhost:3000
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX=120
API_CACHE_TTL_MS=15000
ENABLE_ADMIN_UI=true
ADMIN_BASIC_AUTH_USER=admin
ADMIN_BASIC_AUTH_PASSWORD=change-me
DEFAULT_CURRENCY=USD
TIMESCALE_ENABLED=true
USE_MOCK_PROVIDERS=true
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_RPC_WS_URL=wss://api.devnet.solana.com
SOLANA_KEYPAIR_PATH=./data/solana/devnet-keypair.json
SOLANA_AIRDROP_MIN_BALANCE_SOL=0.25
SOLANA_AIRDROP_TARGET_BALANCE_SOL=1
SOLANA_COMMITMENT=confirmed
SOLANA_PUBLISHER_LABEL=compute-atlas-mvp
SOLANA_MEMO_MAX_BYTES=512
PIPELINE_DEFAULT_SYMBOLS=H100_GLOBAL_SPOT,H100_EU_SPOT,A100_GLOBAL_SPOT
PUBLISH_SYMBOLS=H100_GLOBAL_SPOT,A100_GLOBAL_SPOT
CUSTOM_JSON_FEED_URL=http://localhost:3000/mock/custom-provider.json
NEXT_PUBLIC_APP_NAME=Compute Atlas
NEXT_PUBLIC_REPOSITORY_URL=https://github.com/SebastianBoehler/compute_atlas
