{
  "name": "compute-atlas",
  "private": true,
  "license": "Apache-2.0",
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=22 <23"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/SebastianBoehler/compute_atlas.git"
  },
  "bugs": {
    "url": "https://github.com/SebastianBoehler/compute_atlas/issues"
  },
  "homepage": "https://github.com/SebastianBoehler/compute_atlas",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "format": "biome format --write .",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "db:migrate": "pnpm --filter @compute-atlas/db db:migrate",
    "db:seed": "pnpm --filter @compute-atlas/db db:seed",
    "bootstrap": "bash scripts/bootstrap.sh",
    "verify:devnet": "pnpm --filter @compute-atlas/worker verify:devnet",
    "publish:devnet": "pnpm --filter @compute-atlas/worker publish:devnet",
    "verify:e2e": "bash scripts/verify-e2e.sh",
    "solana:keypair:create": "pnpm --filter @compute-atlas/worker solana:keypair:create",
    "solana:keypair:balance": "pnpm --filter @compute-atlas/worker solana:keypair:balance",
    "worker:pipeline": "pnpm --filter @compute-atlas/worker worker:pipeline"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@types/node": "24.6.1",
    "@types/pg": "8.15.5",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "dotenv-cli": "8.0.0",
    "turbo": "2.5.8",
    "tsx": "4.20.6",
    "typescript": "5.9.3",
    "vitest": "3.2.4"
  }
}
