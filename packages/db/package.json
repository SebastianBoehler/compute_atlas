{
  "name": "@compute-atlas/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "dependencies": {
    "@compute-atlas/config": "workspace:*",
    "@compute-atlas/methodology": "workspace:*",
    "@compute-atlas/providers": "workspace:*",
    "@compute-atlas/types": "workspace:*",
    "drizzle-orm": "0.45.1",
    "dotenv": "17.2.3",
    "pg": "8.16.3"
  },
  "scripts": {
    "db:migrate": "tsx src/migrate.ts",
    "db:seed": "tsx src/seed.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "biome check src",
    "test": "vitest run --passWithNoTests"
  }
}
